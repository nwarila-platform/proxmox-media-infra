# ============================================================================================= #
# .env.example — Environment variables for Proxmox authentication                              #
#                                                                                               #
# Copy this file to .env and update the values for your environment.                            #
# These variables are consumed by Terraform (TF_VAR_*).                                         #
# ============================================================================================= #

# --- Proxmox Settings ---------------------------------------------------------------------- #
TF_VAR_proxmox_hostname="10.69.128.49"
TF_VAR_proxmox_api_token_id="packer@pam!packer_pve_token"
TF_VAR_proxmox_api_token_secret="AAaAAAaA0aaAaaAAAAaAaAaA0AaaaAaaA0aA0aa00a00a0aaAAAaAA0aaaAaAA"
TF_VAR_proxmox_skip_tls_verify="true"
